# Gather - Coordination Assistant
# Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# REQUIRED: OpenAI API Key for the agent
OPENAI_API_KEY=your_openai_api_key_here

# OPTIONAL: OpenWeatherMap API Key for weather features
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# OPTIONAL: Google Places API Key for maps/location features
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# OPTIONAL: n8n Webhook URL for automation workflows
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-id
